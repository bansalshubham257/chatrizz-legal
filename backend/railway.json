{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --no-audit --no-fund"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 5,
    "restartPolicyType": "ON_FAILURE"
  }
}
